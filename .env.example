# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Resend
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM=licenses@yourdomain.com

# Telegram Bot
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Admin
ADMIN_PASSWORD=your_strong_password
ALLOWED_ORIGINS=https://licenses.example.com,https://admin.example.com
TURNSTILE_SECRET_KEY=0x0000000000000000000000000000000AA

# RSA Private Key (содержимое файла keys/private.pem — вставить одной строкой через \n)
LICENSE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
